# Flask App Configurations
SECRET_KEY=generate-a-secure-random-key-here
FLASK_APP=app.py
FLASK_ENV=development

# Target Whatomate PostgreSQL Database Connection (Docker Container Mappings)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here
DB_NAME=whatomate_production

# Target Business Organization Setup
TARGET_ORGANIZATION_NAME=Shiva Developers

# Meta / WhatsApp Embedded Signup API Configurations
META_APP_ID=123456789012345
META_APP_SECRET=your_meta_app_secret_here
META_CONFIG_ID=your_whatsapp_embedded_signup_config_id_here
REDIRECT_URI=http://localhost:5000/auth/oauth-callback
